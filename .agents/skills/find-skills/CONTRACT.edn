(skill-contract
  (name "find-skills")
  (v "ημ.skill/find-skills@0.1.0")

  (intent "Helps users discover and install agent skills when they ask questions like \"how do I do X\", \"find a skill for X\", \"is there a skill that can...\", or express interest in extending capabilities. This skill should be used when the user is looking for functionality that might exist as an installable skill.")

  (activation
    (priority 50)
    (explicit ["skill:find-skills"])
    (triggers ["find a skill for X" "find skills" "how do I do X" "is there a skill that can..."]))

  (governance
    (touch-layer :mutable)
    (non-override [:mission :directives :safety :license :output-shape])
    (requires-user-approval false))
)
