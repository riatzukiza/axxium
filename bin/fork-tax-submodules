#!/usr/bin/env bash
set -euo pipefail

# fork-tax-submodules
# Captures current submodule states into the parent repo (pays the fork tax).
#
# This updates the parent repo's submodule pointers to match
# whatever is currently checked out in each child submodule.

echo "Paying fork tax: capturing submodule states..."

# Stage all submodule pointer updates
git submodule foreach '
  cd "$toplevel"
  git add "$sm_path" 2>/dev/null || true
'

# Only commit if there are changes to submodule pointers
if ! git diff --cached --quiet --ignore-submodules=dirty; then
  git commit -m "fork tax: update submodule pointers to current checkouts"
  echo "Fork tax paid. Submodule pointers updated."
else
  echo "No submodule pointer changes to commit."
fi
