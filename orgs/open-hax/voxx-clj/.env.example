# Voxx Voice Gateway - Clojure Edition
# Copy this file to .env and fill in your values.

# Server
VOICE_GATEWAY_HOST=0.0.0.0
VOICE_GATEWAY_PORT=8788
VOICE_GATEWAY_API_KEY=
VOICE_GATEWAY_DATA_DIR=data
VOICE_GATEWAY_DEFAULT_AUDIO_FORMAT=mp3
VOICE_GATEWAY_DEFAULT_LANGUAGE=en

# TTS backend order (comma-separated, first available wins)
# Options: kokoro, xiaomi_mimo, requesty, openai, melo, espeak
VOICE_GATEWAY_TTS_BACKEND_ORDER=
VOICE_GATEWAY_TTS_DEVICE=auto
VOICE_GATEWAY_TTS_EAGER_LOAD=false
VOICE_GATEWAY_TTS_REMOTE_TIMEOUT_SECONDS=45

# TTS queue limits
TTS_QUEUE_MAX_CONCURRENT=1
TTS_QUEUE_MAX_PENDING=32
TTS_QUEUE_TIMEOUT_SECONDS=120

# Requesty
REQUESTY_API_TOKEN=
REQUESTY_TTS_BASE_URL=https://router.requesty.ai/v1/audio/speech
REQUESTY_TTS_MODEL=openai/gpt-4o-mini-tts
REQUESTY_TTS_VOICE=ash

# OpenAI
OPENAI_API_KEY=
OPENAI_TTS_BASE_URL=https://api.openai.com/v1/audio/speech
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=ash

# Xiaomi MiMo
XIAOMI_MIMO_API_KEY=
XIAOMI_MIMO_API_BASE_URL=https://api.xiaomimimo.com/v1
XIAOMI_MIMO_TTS_MODEL=mimo-v2.5-tts
XIAOMI_MIMO_TTS_VOICE=mimo_default
XIAOMI_MIMO_TTS_STYLE=Speak naturally and clearly.

# Kokoro
KOKORO_API_KEY=
KOKORO_TTS_BASE_URL=http://kokoro:8880/v1/audio/speech
KOKORO_TTS_MODEL=kokoro
KOKORO_TTS_VOICE=af_bella_725_H

# TTS postprocess
TTS_POSTPROCESS_ENABLED=true
TTS_POSTPROCESS_PROFILE=sports-commentator-v1
TTS_PROMPT_AWARE_DEFAULT=true

# Narrator unifier
TTS_NARRATOR_UNIFIER_ENABLED=true
TTS_NARRATOR_TARGET_DBFS=-18.0

# STT
VOICE_GATEWAY_STT_ENABLED=false
FASTER_WHISPER_MODEL=small
FASTER_WHISPER_DEVICE=auto
FASTER_WHISPER_COMPUTE_TYPE=int8
WHISPER_CPP_BIN=whisper-cli
WHISPER_CPP_MODEL=
