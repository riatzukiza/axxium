# Axxium Identity Provider Configuration

# Server
AXXIUM_PORT=8787
AXXIUM_HOST=0.0.0.0
AXXIUM_PUBLIC_BASE_URL=http://localhost:8787

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=axxium
DB_USER=axxium
DB_PASSWORD=axxium_password

# JWT
JWT_SECRET=change-me-in-production
JWT_ISSUER=axxium
JWT_AUDIENCE=promethean
JWT_EXPIRY_HOURS=168

# Session
SESSION_COOKIE_NAME=axxium_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

# Password hashing
BCRYPT_SALT_ROUNDS=12

# OAuth (optional)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_ENABLED=false
