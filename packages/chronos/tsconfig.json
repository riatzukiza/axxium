{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "REDACTED_SECRETDir": "./src",
    "types": ["bun-types"]
  },
  "include": ["src/**/*", "tools/**/*"],
  "exclude": ["REDACTED_SECRET_modules", "dist"]
}