{
  "name": "eta-mu-five-section-response",
  "version": "ημ.output/response-shape@0.1.0",
  "targetFormat": "markdown",
  "targetAst": "mdast",
  "targetRoot": "document",
  "repairMaxRetries": 2,
  "sections": [
    {
      "id": "section/signal",
      "heading": "Signal",
      "required": true,
      "order": 1,
      "cardinality": "one",
      "allowedNodeTypes": [
        "paragraph",
        "list",
        "blockquote",
        "code",
        "table"
      ],
      "localRuleIds": []
    },
    {
      "id": "section/evidence",
      "heading": "Evidence",
      "required": true,
      "order": 2,
      "cardinality": "one",
      "allowedNodeTypes": [
        "paragraph",
