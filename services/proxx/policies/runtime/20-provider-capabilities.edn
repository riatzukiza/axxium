[{:contract/id :provider-order/gpt-default
  :contract/kind :preference-order
  :preference/items ["openai"]}

 {:contract/id :provider-order/gpt-oss
  :contract/kind :preference-order
  :preference/items ["ollama-cloud"]}

 {:contract/id :provider-order/claude-opus-4-6
  :contract/kind :preference-order
  :preference/items ["factory" "openrouter" "requesty" "vivgrid"]}

 {:contract/id :provider-order/glm
  :contract/kind :preference-order
  :preference/items ["zai" "rotussy" "requesty" "factory" "openrouter" "vivgrid" "ollama-cloud"]}

 {:contract/id :provider-order/kimi
  :contract/kind :preference-order
  :preference/items ["kimi" "moonshotai" "factory" "openrouter" "requesty" "vivgrid"]}

 {:contract/id :provider-route/kimi
  :contract/kind :provider-route
  :provider/id "kimi"
  :provider/base-url "https://api.moonshot.ai/v1"}

 {:contract/id :provider-order/mimo-official
  :contract/kind :preference-order
  :preference/items ["xiaomi"]}

 {:contract/id :provider-order/mimo
  :contract/kind :preference-order
  :preference/items ["xiaomi"]}

 {:contract/id :provider-order/embeddings
  :contract/kind :preference-order
  :preference/items ["llamacpp-embed" "ollama"]}

 {:contract/id :provider-order/gemma
  :contract/kind :preference-order
  :preference/items ["ollama-cloud" "ollama"]}

 {:contract/id :provider-capability/gemini-chat
  :contract/kind :provider-capability
  :match/provider-pattern "^gemini$"
  :match/request-kind :chat
  :prefer/strategies [:gemini-chat]}

 {:contract/id :provider-capability/zai-chat
  :contract/kind :provider-capability
  :match/provider-pattern "^zai$"
  :match/request-kind :chat
  :prefer/strategies [:chat-completions]
  :exclude/strategies [:responses :messages]}

 {:contract/id :provider-capability/rotussy-responses-passthrough
  :contract/kind :provider-capability
  :match/provider-pattern "^rotussy$"
  :match/request-kind :responses-passthrough
  :prefer/strategies [:chat-completions]
  :exclude/strategies [:responses-passthrough]}

 {:contract/id :provider-capability/kimi-chat
  :contract/kind :provider-capability
  :match/provider-pattern "^(kimi|moonshotai)$"
  :match/request-kind :chat
  :prefer/strategies [:chat-completions]
  :exclude/strategies [:ollama-chat :responses :messages]}

 {:contract/id :provider-capability/openai-compatible-chat
  :contract/kind :provider-capability
  :match/provider-pattern "^(openrouter|requesty|ob1|zen|xiaomi)$"
  :match/request-kind :chat
  :exclude/strategies [:messages]}

 {:contract/id :request-surface/images-passthrough
  :contract/kind :request-surface-default
  :match/provider-pattern ".*"
  :match/request-kind :images-passthrough
  :prefer/strategies [:images]}

 {:contract/id :request-surface/responses-passthrough
  :contract/kind :request-surface-default
  :match/provider-pattern ".*"
  :match/request-kind :responses-passthrough
  :prefer/strategies [:openai-responses-passthrough :responses-passthrough :chat-completions]}

 {:contract/id :request-surface/embeddings
  :contract/kind :request-surface-default
  :match/provider-pattern "^(llamacpp-embed|ollama)$"
  :match/request-kind :embeddings
  :prefer/strategies [:embeddings]}]
