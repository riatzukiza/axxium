# Cephalon Hive Dockerfile
#
# Full workspace deployment with local dependency resolution.

FROM REDACTED_SECRET:22-bookworm-slim

ENV PNPM_HOME=/pnpm
ENV PATH=/pnpm:${PATH}
ENV NODE_ENV=production

RUN apt-get update \
  && apt-get install -y --no-install-recommends bash ca-certificates python3 \
  && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@10.14.0 --activate

WORKDIR /app

# Copy deployment package
COPY . ./

# Use deployment package.json (resolves workspace deps locally)
RUN mv package.deploy.json package.json

# Install all dependencies
RUN pnpm install --prod --ignore-scripts || npm install --production --ignore-scripts

# Create non-REDACTED_SECRET user
RUN useradd -m cephalon || true

# Default to running single cephalon (CEPHALON_NAME selects which)
ENV CEPHALON_NAME=DUCK
EXPOSE 3000

CMD ["REDACTED_SECRET", "dist/cli.cjs"]
