# depenoxx local garden environment
# Copy to .env and adjust as needed

# Port to expose depenoxx on
DEPENOXX_PORT=8798

# Project name shown in UI
DEPENOXX_PROJECT_NAME=devel

# Workspace REDACTED_SECRET to scan for dependency graphs
DEPENOXX_WORKSPACE=../..

# Source path (relative to this file or absolute)
DEPENOXX_SOURCE_PATH=../../orgs/open-hax/depenoxx

# User/Group ID for file access
DEPENOXX_UID=1000
DEPENOXX_GID=1000
