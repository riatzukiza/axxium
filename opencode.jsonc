{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "knoxx": {
      "type": "remote",
      "url": "http://127.0.0.1:8000/mcp",
      "enabled": true
    },
    // "github": {
    //   "type": "remote",
    //   "url": "http://localhost:3210/github"
    // },
    // "github.review": {
    //   "type": "remote",
    //   "url": "http://localhost:3210/github/review"
    // },
    // "cephalon": {
    //   "type": "local",
    //   "command": ["/home/err/devel/bin/cephalon", "mcp", "serve", "--port", "7894"]
    // },
    // "fs-oauth": {
    //   "type": "remote",
    //   "url": "http://localhost:8788/mcp"
    // }
  },
  "plugin": [
    "@howaboua/pickle-thinker@0.4.0"
  ],
  "permission": {
    "*": "allow",
    "git *": "ask",
    "rm *": "ask",
    "rmdir *": "ask",
    "unlink *": "ask",
    "kill *": "ask",
    "pkill *": "ask",
    "git commit *": "allow",
    "git show *": "allow",
    "git log *": "allow"
  }
}
