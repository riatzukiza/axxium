# Data volumes
/data/

# Service runtime data volumes (local-only; never track service state)
services/*/data/
services/*/.data/
services/*/runtime-secrets/
services/*/secrets/
services/*/storage/
services/*/uploads/
services/*/tmp/

# Secrets (keep patterns, never track contents)
.env
.env.*
!.env.example
keys.json
models.json

# Factory / scaffolding
.factory/

# Inbox — unstructured imports, binary exports, not source
inbox/

# Tmp — scratch space, test artifacts, not source
tmp/

# Private repos — no upstream to push to, should not be in this repo's tracking
orgs/private/

# Stale path — renamed to orgs/riatzukiza/mnemosyne
packages/cephalon-ts/

# services/ourllamas — archived, has __pycache__ bleed
services/ourllamas/

# Generated audit artifacts
tools/ui-audit/component-frequency.json

# Large runtime logs
*.jsonl
services/proxx/data-federation/request-logs.jsonl

# Database dumps
*.dump

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Docker volumes / runtime secrets
services/openplanner/runtime-secrets/

# Pi session HTML dumps
pi-session-*.html

# Node compile cache
node-compile-cache/

# docs/inbox — duplicate of inbox/, not reference material
docs/inbox/

