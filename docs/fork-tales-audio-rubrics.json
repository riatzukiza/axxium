{
  "schema_version": "fork-tales-audio-rubrics/v1",
  "scale": {
    "score": "0.0 = unusable, 0.5 = partial/diagnostic, 0.8 = production-usable, 0.9 = excellent, 1.0 = near-reference",
    "confidence": "0.0 = no usable evidence, 1.0 = high agreement among reliable available judges",
    "coverage": "fraction of configured judge reliability that was available for the feature"
  },
  "evidence_classes": {
    "lyric_prompt": {
      "description": "User/Suno lyric text and style prompt. Useful dictionary clue but not timing truth and not guaranteed to match generated audio.",
      "failure_modes": ["Suno skipped or changed words", "Kanji reading differs from intended reading", "Style prompt words leak into sung output"]
    },
    "local_stt": {
      "description": "Local timed STT/Whisper-like transcript from original and candidate audio.",
      "failure_modes": ["Japanese homophones", "mixed-language switching", "sung vowels/held notes collapsed", "English hallucination on Japanese audio"]
    },
    "gemma_audio": {
      "description": "Gemma audio model direct listening over audio-first payload plus explicit tool evidence.",
      "failure_modes": ["Over-trusts prompt text", "A/B contamination", "resource failures on long audio", "weak voiced/unvoiced Japanese consonant discrimination"]
    },
    "f0_tracker": {
      "description": "Deterministic f0 contour extraction such as librosa.pyin, CREPE, SPICE, or equivalent.",
      "failure_modes": ["Octave errors", "unvoiced regions", "polyphonic/stem bleed", "breathy vocals"]
    },
    "spectrogram_metrics": {
      "description": "Numeric comparison over mel/spectral representations: RMSE, correlation, spectral centroid, energy envelopes.",
      "failure_modes": ["Sensitive to mix/timbre differences", "weak semantic interpretation", "may punish valid alternate instrumentation"]
    },
    "spectrogram_image_judge": {
      "description": "Vision model or human reading spectrogram/f0 overlay images for contour, articulation, vibrato, onsets, and sometimes phonetic clues.",
      "failure_modes": ["Image scale/color misread", "weak lyric inference", "requires calibrated axes", "may see patterns that are visually salient but musically irrelevant"]
    },
    "ustx_midi_grid": {
      "description": "Symbolic note/phoneme grid: USTX, MIDI, note starts, durations, ties, pitch-bend/control curves, voicebank aliases.",
      "failure_modes": ["Grid can be internally consistent but audibly wrong", "phonemizer aliases missing", "tick rounding changes words"]
    },
    "human_user": {
      "description": "Human/user judgment, especially for taste, intent, language nuance, and final accept/reject decisions.",
      "failure_modes": ["fatigue", "language fluency limits", "preference drift", "memory bias"]
    },
    "gemini_text_audio": {
      "description": "Optional stronger external model through Proxx/Google AI Studio for resolving lyric prompt vs transcript differences and high-level quality critique.",
      "failure_modes": ["not local/free", "can normalize away actual Suno deviations", "may overfit to written lyric prompt"]
    }
  },
